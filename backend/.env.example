# Copy this file to backend/.env and fill in your real keys.
# backend/.env is gitignored — never commit secrets.

# --- Anthropic (Claude) ---
# Required for /api/perception and /api/plan-animation.
# Two mutually exclusive options depending on your auth style:
#   - ANTHROPIC_API_KEY   — sent as the `x-api-key` header (native Anthropic).
#   - ANTHROPIC_AUTH_TOKEN — sent as `Authorization: Bearer ...` (common for
#                           OneAPI / reverse-proxy gateways).
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

# Optional: point the Anthropic SDK at a proxy/gateway. Leave empty to use
# the SDK's default public endpoint.
ANTHROPIC_BASE_URL=

# --- Replicate (SAM2 + SD inpainting) ---
# Required only when USE_REPLICATE_FALLBACK is not set. When this token is
# missing, the backend automatically switches /api/segment and /api/inpaint
# to local Pillow fallbacks (rectangular bbox crops + Gaussian-blur fill).
REPLICATE_API_TOKEN=

# Optional: force the Pillow fallback even when REPLICATE_API_TOKEN is set.
# Useful for local dev and CI where you want to avoid Replicate costs.
# Accepts: 1 | true | yes (case-insensitive).
USE_REPLICATE_FALLBACK=
