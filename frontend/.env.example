# Copy to frontend/.env.local if you need to override defaults. Vite only
# exposes variables prefixed with VITE_ to the client bundle.

# Base URL the frontend uses when calling the backend API.
# Defaults to http://localhost:8000 when unset (see src/lib/api.ts).
# Set this only if the backend runs on a non-default host/port.
VITE_API_BASE_URL=
